# ============================================================
# AIOps Pipeline — .env
# ⚠️  NEVER commit this file to version control.
#     Add .env to your .gitignore immediately.
#
# How to use:
#   1. Fill in the values marked  ← REQUIRED
#   2. Adjust optional values to match your environment
#   3. docker compose up -d
# ============================================================


# ────────────────────────────────────────────────────────────
# LLM — Google Gemini
# Get your key: https://aistudio.google.com/app/apikey
# ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here                      # ← REQUIRED


# ────────────────────────────────────────────────────────────
# ALERTING
# Slack:      https://api.slack.com/messaging/webhooks
# PagerDuty:  https://developer.pagerduty.com/docs/events-api-v2
# Teams:      https://learn.microsoft.com/en-us/microsoftteams/platform/webhooks-and-connectors/how-to/add-incoming-webhook
# Leave blank to fall back to log-only alerting (safe for local dev)
# ────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK


# ────────────────────────────────────────────────────────────
# MONGODB
# These must match the values in docker-compose.yml
# ────────────────────────────────────────────────────────────
MONGO_USER=aiops
MONGO_PASSWORD=changeme_in_prod
MONGO_URI=mongodb://aiops:changeme_in_prod@mongodb:27017/


# ────────────────────────────────────────────────────────────
# REDIS
# ────────────────────────────────────────────────────────────
REDIS_URI=redis://redis:6379/0


# ────────────────────────────────────────────────────────────
# LOKI
# ────────────────────────────────────────────────────────────
LOKI_URL=http://loki:3100
LOKI_QUERY={job="fluent-bit"}


# ────────────────────────────────────────────────────────────
# PROMETHEUS
# ────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090


# ────────────────────────────────────────────────────────────
# GRAFANA
# ────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_in_prod


# ────────────────────────────────────────────────────────────
# PIPELINE BEHAVIOUR
# ────────────────────────────────────────────────────────────

# How many minutes of logs to pull per run
FETCH_WINDOW_MINS=5

# Max log lines fetched from Loki per run
LOG_FETCH_LIMIT=200

# HTTP timeout (seconds) for all outbound requests
REQUEST_TIMEOUT=10

# Deployment target: server | kubernetes | serverless
DEPLOYMENT_ENV=server

# Log output format: json (production) | console (local dev)
LOG_FORMAT=json